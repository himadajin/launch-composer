{
  "name": "launch-composer",
  "displayName": "Launch Composer",
  "description": "Compose VSCode launch.json from templates and configs.",
  "version": "0.1.0",
  "publisher": "himadajin",
  "license": "MIT",
  "homepage": "https://github.com/himadajin/launch-composer",
  "repository": {
    "type": "git",
    "url": "https://github.com/himadajin/launch-composer.git"
  },
  "bugs": {
    "url": "https://github.com/himadajin/launch-composer/issues"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "build:test": "node test/build-tests.mjs",
    "test": "npm run build && npm run build:test && node --test .test-dist/*.test.js",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@launch-composer/core": "0.1.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.11"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "launchComposer",
          "title": "Launch Composer",
          "icon": "resources/launch-composer.svg"
        }
      ]
    },
    "views": {
      "launchComposer": [
        {
          "id": "launchComposer.templates",
          "name": "TEMPLATES"
        },
        {
          "id": "launchComposer.configs",
          "name": "CONFIGS"
        }
      ]
    },
    "commands": [
      {
        "command": "launch-composer.generate",
        "title": "Generate launch.json",
        "category": "Launch Composer",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(play)"
      },
      {
        "command": "launch-composer.init",
        "title": "Initialize",
        "category": "Launch Composer",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addTemplate",
        "title": "Add Template",
        "category": "Launch Composer",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addTemplateFile",
        "title": "Add Template File",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.openTemplateFileJson",
        "title": "Open",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyTemplateFilePath",
        "title": "Copy Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyTemplateFileRelativePath",
        "title": "Copy Relative Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.renameTemplateFile",
        "title": "Rename",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.deleteTemplateFile",
        "title": "Delete",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addTemplateEntry",
        "title": "Add Template",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.addConfigFile",
        "title": "Add Config File",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.openConfigFileJson",
        "title": "Open",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyConfigFilePath",
        "title": "Copy Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyConfigFileRelativePath",
        "title": "Copy Relative Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.renameConfigFile",
        "title": "Rename",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.deleteConfigFile",
        "title": "Delete",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addConfigEntry",
        "title": "Add Config",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.editItem",
        "title": "Edit",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.openItemJson",
        "title": "Open",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyItemFilePath",
        "title": "Copy Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyItemFileRelativePath",
        "title": "Copy Relative Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.renameItem",
        "title": "Rename",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.deleteItem",
        "title": "Delete",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.enableConfig",
        "title": "Enable",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.disableConfig",
        "title": "Disable",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.toggleEnabled",
        "title": "Toggle Enabled",
        "enablement": "workspaceFolderCount == 1"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "launch-composer.addTemplateFile",
          "when": "view == launchComposer.templates",
          "group": "navigation"
        },
        {
          "command": "launch-composer.addConfigFile",
          "when": "view == launchComposer.configs",
          "group": "navigation"
        },
        {
          "command": "launch-composer.generate",
          "when": "view == launchComposer.configs",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "launch-composer.addTemplateEntry",
          "when": "view == launchComposer.templates && viewItem == templateFile",
          "group": "1_new@1"
        },
        {
          "command": "launch-composer.addConfigEntry",
          "when": "view == launchComposer.configs && viewItem == configFile",
          "group": "1_new@1"
        },
        {
          "command": "launch-composer.openTemplateFileJson",
          "when": "view == launchComposer.templates && (viewItem == templateFile || viewItem == templateFileInvalid)",
          "group": "2_open@1"
        },
        {
          "command": "launch-composer.copyTemplateFilePath",
          "when": "view == launchComposer.templates && (viewItem == templateFile || viewItem == templateFileInvalid)",
          "group": "3_copy@1"
        },
        {
          "command": "launch-composer.copyTemplateFileRelativePath",
          "when": "view == launchComposer.templates && (viewItem == templateFile || viewItem == templateFileInvalid)",
          "group": "3_copy@2"
        },
        {
          "command": "launch-composer.renameTemplateFile",
          "when": "view == launchComposer.templates && (viewItem == templateFile || viewItem == templateFileInvalid)",
          "group": "4_modify@1"
        },
        {
          "command": "launch-composer.deleteTemplateFile",
          "when": "view == launchComposer.templates && (viewItem == templateFile || viewItem == templateFileInvalid)",
          "group": "5_delete@1"
        },
        {
          "command": "launch-composer.openConfigFileJson",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "2_open@1"
        },
        {
          "command": "launch-composer.copyConfigFilePath",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "3_copy@1"
        },
        {
          "command": "launch-composer.copyConfigFileRelativePath",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "3_copy@2"
        },
        {
          "command": "launch-composer.renameConfigFile",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "4_modify@1"
        },
        {
          "command": "launch-composer.enableConfig",
          "when": "viewItem == configEntryDisabled",
          "group": "0_state@1"
        },
        {
          "command": "launch-composer.disableConfig",
          "when": "viewItem == configEntryEnabled",
          "group": "0_state@1"
        },
        {
          "command": "launch-composer.deleteConfigFile",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "5_delete@1"
        },
        {
          "command": "launch-composer.openItemJson",
          "when": "viewItem == templateEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "2_open@1"
        },
        {
          "command": "launch-composer.copyItemFilePath",
          "when": "viewItem == templateEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "3_copy@1"
        },
        {
          "command": "launch-composer.copyItemFileRelativePath",
          "when": "viewItem == templateEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "3_copy@2"
        },
        {
          "command": "launch-composer.renameItem",
          "when": "viewItem == templateEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "4_modify@1"
        },
        {
          "command": "launch-composer.deleteItem",
          "when": "viewItem == templateEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "5_delete@1"
        }
      ],
      "view/item/inline": [
        {
          "command": "launch-composer.addTemplateEntry",
          "when": "view == launchComposer.templates && viewItem == templateFile",
          "group": "inline"
        },
        {
          "command": "launch-composer.addConfigEntry",
          "when": "view == launchComposer.configs && viewItem == configFile",
          "group": "inline"
        },
        {
          "command": "launch-composer.toggleEnabled",
          "when": "viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "launch-composer.addTemplateFile",
          "when": "false"
        },
        {
          "command": "launch-composer.openTemplateFileJson",
          "when": "false"
        },
        {
          "command": "launch-composer.copyTemplateFilePath",
          "when": "false"
        },
        {
          "command": "launch-composer.copyTemplateFileRelativePath",
          "when": "false"
        },
        {
          "command": "launch-composer.renameTemplateFile",
          "when": "false"
        },
        {
          "command": "launch-composer.deleteTemplateFile",
          "when": "false"
        },
        {
          "command": "launch-composer.addTemplateEntry",
          "when": "false"
        },
        {
          "command": "launch-composer.addConfigFile",
          "when": "false"
        },
        {
          "command": "launch-composer.openConfigFileJson",
          "when": "false"
        },
        {
          "command": "launch-composer.copyConfigFilePath",
          "when": "false"
        },
        {
          "command": "launch-composer.copyConfigFileRelativePath",
          "when": "false"
        },
        {
          "command": "launch-composer.renameConfigFile",
          "when": "false"
        },
        {
          "command": "launch-composer.deleteConfigFile",
          "when": "false"
        },
        {
          "command": "launch-composer.addConfigEntry",
          "when": "false"
        },
        {
          "command": "launch-composer.editItem",
          "when": "false"
        },
        {
          "command": "launch-composer.openItemJson",
          "when": "false"
        },
        {
          "command": "launch-composer.copyItemFilePath",
          "when": "false"
        },
        {
          "command": "launch-composer.copyItemFileRelativePath",
          "when": "false"
        },
        {
          "command": "launch-composer.renameItem",
          "when": "false"
        },
        {
          "command": "launch-composer.deleteItem",
          "when": "false"
        },
        {
          "command": "launch-composer.enableConfig",
          "when": "false"
        },
        {
          "command": "launch-composer.disableConfig",
          "when": "false"
        },
        {
          "command": "launch-composer.toggleEnabled",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "launchComposer.templates",
        "contents": "No template files found. [Create Template File](command:launch-composer.addTemplateFile)"
      },
      {
        "view": "launchComposer.configs",
        "contents": "No config files found. [Create Config File](command:launch-composer.addConfigFile)"
      }
    ],
    "configuration": {
      "title": "Launch Composer",
      "properties": {
        "launch-composer.confirmOverwrite": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before overwriting launch.json."
        },
        "launch-composer.autoSaveDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 0,
          "description": "Debounce delay in milliseconds before saving text field edits from the webview."
        }
      }
    }
  }
}
