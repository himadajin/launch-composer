{
  "name": "launch-composer",
  "displayName": "Launch Composer",
  "description": "Compose VS Code launch.json from profiles and configs.",
  "version": "0.1.1",
  "publisher": "himadajin",
  "license": "MIT",
  "homepage": "https://github.com/himadajin/launch-composer",
  "repository": {
    "type": "git",
    "url": "https://github.com/himadajin/launch-composer.git"
  },
  "bugs": {
    "url": "https://github.com/himadajin/launch-composer/issues"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "build:test": "node test/build-tests.mjs",
    "install:vscode": "npm run package && code --install-extension launch-composer.vsix --force",
    "test": "npm run build && npm run build:test && node --test .test-dist/*.test.js",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "npm run build -w @launch-composer/core && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "package": "vsce package --no-dependencies --out launch-composer.vsix"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@launch-composer/core": "0.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "launchComposer",
          "title": "Launch Composer",
          "icon": "resources/launch-composer.svg"
        }
      ]
    },
    "views": {
      "launchComposer": [
        {
          "id": "launchComposer.configs",
          "name": "CONFIGS"
        },
        {
          "id": "launchComposer.profiles",
          "name": "PROFILES"
        }
      ]
    },
    "commands": [
      {
        "command": "launch-composer.generate",
        "title": "Generate launch.json",
        "category": "Launch Composer",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(play)"
      },
      {
        "command": "launch-composer.init",
        "title": "Initialize",
        "category": "Launch Composer",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addProfile",
        "title": "Add Profile",
        "category": "Launch Composer",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addProfileFile",
        "title": "Add Profile File",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.openProfileFileJson",
        "title": "Open",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyProfileFilePath",
        "title": "Copy Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyProfileFileRelativePath",
        "title": "Copy Relative Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.renameProfileFile",
        "title": "Rename",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.deleteProfileFile",
        "title": "Delete",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addProfileEntry",
        "title": "Add Profile",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.addConfigFile",
        "title": "Add Config File",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.openConfigFileJson",
        "title": "Open",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyConfigFilePath",
        "title": "Copy Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyConfigFileRelativePath",
        "title": "Copy Relative Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.renameConfigFile",
        "title": "Rename",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.deleteConfigFile",
        "title": "Delete",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.addConfigEntry",
        "title": "Add Config",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(add)"
      },
      {
        "command": "launch-composer.includeAllConfigs",
        "title": "Include All Configs",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.excludeAllConfigs",
        "title": "Exclude All Configs",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.editItem",
        "title": "Edit",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(gear)"
      },
      {
        "command": "launch-composer.openActiveEditorJson",
        "title": "Open JSON",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(go-to-file)"
      },
      {
        "command": "launch-composer.openItemJson",
        "title": "Open",
        "enablement": "workspaceFolderCount == 1",
        "icon": "$(go-to-file)"
      },
      {
        "command": "launch-composer.copyItemFilePath",
        "title": "Copy Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.copyItemFileRelativePath",
        "title": "Copy Relative Path",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.renameItem",
        "title": "Rename",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.deleteItem",
        "title": "Delete",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.includeConfig",
        "title": "Include",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.excludeConfig",
        "title": "Exclude",
        "enablement": "workspaceFolderCount == 1"
      },
      {
        "command": "launch-composer.toggleIncluded",
        "title": "Toggle Included",
        "enablement": "workspaceFolderCount == 1"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "launch-composer.openActiveEditorJson",
          "when": "activeWebviewPanelId == 'launchComposer.editor'",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "launch-composer.addProfileFile",
          "when": "view == launchComposer.profiles",
          "group": "navigation"
        },
        {
          "command": "launch-composer.addConfigFile",
          "when": "view == launchComposer.configs",
          "group": "navigation"
        },
        {
          "command": "launch-composer.generate",
          "when": "view == launchComposer.configs",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "launch-composer.addProfileEntry",
          "when": "view == launchComposer.profiles && viewItem == profileFile",
          "group": "1_new@1"
        },
        {
          "command": "launch-composer.addConfigEntry",
          "when": "view == launchComposer.configs && viewItem == configFile",
          "group": "1_new@1"
        },
        {
          "command": "launch-composer.openProfileFileJson",
          "when": "view == launchComposer.profiles && (viewItem == profileFile || viewItem == profileFileInvalid)",
          "group": "2_open@1"
        },
        {
          "command": "launch-composer.copyProfileFilePath",
          "when": "view == launchComposer.profiles && (viewItem == profileFile || viewItem == profileFileInvalid)",
          "group": "3_copy@1"
        },
        {
          "command": "launch-composer.copyProfileFileRelativePath",
          "when": "view == launchComposer.profiles && (viewItem == profileFile || viewItem == profileFileInvalid)",
          "group": "3_copy@2"
        },
        {
          "command": "launch-composer.renameProfileFile",
          "when": "view == launchComposer.profiles && (viewItem == profileFile || viewItem == profileFileInvalid)",
          "group": "4_modify@1"
        },
        {
          "command": "launch-composer.deleteProfileFile",
          "when": "view == launchComposer.profiles && (viewItem == profileFile || viewItem == profileFileInvalid)",
          "group": "5_delete@1"
        },
        {
          "command": "launch-composer.openConfigFileJson",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "2_open@1"
        },
        {
          "command": "launch-composer.copyConfigFilePath",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "3_copy@1"
        },
        {
          "command": "launch-composer.copyConfigFileRelativePath",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "3_copy@2"
        },
        {
          "command": "launch-composer.renameConfigFile",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "4_modify@1"
        },
        {
          "command": "launch-composer.includeAllConfigs",
          "when": "view == launchComposer.configs && viewItem == configFile",
          "group": "0_state@1"
        },
        {
          "command": "launch-composer.excludeAllConfigs",
          "when": "view == launchComposer.configs && viewItem == configFile",
          "group": "0_state@2"
        },
        {
          "command": "launch-composer.includeConfig",
          "when": "viewItem == configEntryDisabled",
          "group": "0_state@1"
        },
        {
          "command": "launch-composer.excludeConfig",
          "when": "viewItem == configEntryEnabled",
          "group": "0_state@1"
        },
        {
          "command": "launch-composer.deleteConfigFile",
          "when": "view == launchComposer.configs && (viewItem == configFile || viewItem == configFileInvalid)",
          "group": "5_delete@1"
        },
        {
          "command": "launch-composer.openItemJson",
          "when": "viewItem == profileEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "2_open@1"
        },
        {
          "command": "launch-composer.copyItemFilePath",
          "when": "viewItem == profileEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "3_copy@1"
        },
        {
          "command": "launch-composer.copyItemFileRelativePath",
          "when": "viewItem == profileEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "3_copy@2"
        },
        {
          "command": "launch-composer.renameItem",
          "when": "viewItem == profileEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "4_modify@1"
        },
        {
          "command": "launch-composer.deleteItem",
          "when": "viewItem == profileEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "5_delete@1"
        },
        {
          "command": "launch-composer.addProfileEntry",
          "when": "view == launchComposer.profiles && viewItem == profileFile",
          "group": "inline"
        },
        {
          "command": "launch-composer.addConfigEntry",
          "when": "view == launchComposer.configs && viewItem == configFile",
          "group": "inline"
        },
        {
          "command": "launch-composer.openItemJson",
          "when": "viewItem == profileEntry || viewItem == configEntryEnabled || viewItem == configEntryDisabled",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "launch-composer.addProfileFile",
          "when": "false"
        },
        {
          "command": "launch-composer.openProfileFileJson",
          "when": "false"
        },
        {
          "command": "launch-composer.copyProfileFilePath",
          "when": "false"
        },
        {
          "command": "launch-composer.copyProfileFileRelativePath",
          "when": "false"
        },
        {
          "command": "launch-composer.renameProfileFile",
          "when": "false"
        },
        {
          "command": "launch-composer.deleteProfileFile",
          "when": "false"
        },
        {
          "command": "launch-composer.addProfileEntry",
          "when": "false"
        },
        {
          "command": "launch-composer.addConfigFile",
          "when": "false"
        },
        {
          "command": "launch-composer.openConfigFileJson",
          "when": "false"
        },
        {
          "command": "launch-composer.copyConfigFilePath",
          "when": "false"
        },
        {
          "command": "launch-composer.copyConfigFileRelativePath",
          "when": "false"
        },
        {
          "command": "launch-composer.renameConfigFile",
          "when": "false"
        },
        {
          "command": "launch-composer.deleteConfigFile",
          "when": "false"
        },
        {
          "command": "launch-composer.addConfigEntry",
          "when": "false"
        },
        {
          "command": "launch-composer.includeAllConfigs",
          "when": "false"
        },
        {
          "command": "launch-composer.excludeAllConfigs",
          "when": "false"
        },
        {
          "command": "launch-composer.editItem",
          "when": "false"
        },
        {
          "command": "launch-composer.openItemJson",
          "when": "false"
        },
        {
          "command": "launch-composer.copyItemFilePath",
          "when": "false"
        },
        {
          "command": "launch-composer.copyItemFileRelativePath",
          "when": "false"
        },
        {
          "command": "launch-composer.renameItem",
          "when": "false"
        },
        {
          "command": "launch-composer.deleteItem",
          "when": "false"
        },
        {
          "command": "launch-composer.includeConfig",
          "when": "false"
        },
        {
          "command": "launch-composer.excludeConfig",
          "when": "false"
        },
        {
          "command": "launch-composer.toggleIncluded",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "launchComposer.profiles",
        "contents": "No profile files found. [Create Profile File](command:launch-composer.addProfileFile)"
      },
      {
        "view": "launchComposer.configs",
        "contents": "No config files found. [Create Config File](command:launch-composer.addConfigFile)"
      }
    ],
    "configuration": {
      "title": "Launch Composer",
      "properties": {
        "launch-composer.confirmOverwrite": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before overwriting launch.json."
        },
        "launch-composer.autoSaveDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 0,
          "description": "Debounce delay in milliseconds before saving text field edits from the webview."
        }
      }
    }
  }
}
